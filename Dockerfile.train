FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /workspace

COPY requirements-train.txt /workspace/requirements-train.txt
RUN pip install --upgrade pip && pip install -r /workspace/requirements-train.txt

COPY . /workspace
RUN pip install -e .

CMD ["python", "scripts/train_mlp.py", "--train-episodes", "1200", "--eval-seed-count", "300", "--policy-out", "artifacts/trained_policy_mlp.npz", "--policy-metadata-out", "artifacts/policy_metadata.json", "--metrics-out", "artifacts/evaluation_metrics.json"]
